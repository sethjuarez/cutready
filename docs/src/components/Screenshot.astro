---
interface Props {
  src: string;
  alt: string;
  caption?: string;
  darkSrc?: string;
}

const { src, alt, caption, darkSrc } = Astro.props;
---

<figure class="screenshot">
  {darkSrc ? (
    <>
      <img src={src} alt={alt} loading="lazy" class="screenshot-light" data-lightbox-src={src} />
      <img src={darkSrc} alt={alt} loading="lazy" class="screenshot-dark" data-lightbox-src={darkSrc} />
    </>
  ) : (
    <img src={src} alt={alt} loading="lazy" data-lightbox-src={src} />
  )}
  {caption && <figcaption style="padding: 0.5rem 1rem; font-size: var(--sl-text-xs); color: var(--sl-color-text-accent); text-align: center;">{caption}</figcaption>}
</figure>

<script>
  // Screenshot lightbox — appends overlay to <body> so it escapes any stacking context
  function initLightbox() {
    document.querySelectorAll<HTMLImageElement>('.screenshot img[data-lightbox-src]').forEach((img) => {
      if (img.dataset.lightboxBound) return;
      img.dataset.lightboxBound = 'true';
      img.style.cursor = 'zoom-in';
      img.addEventListener('click', () => {
        const src = img.dataset.lightboxSrc!;
        const alt = img.alt;
        const overlay = document.createElement('div');
        overlay.className = 'screenshot-lightbox active';
        overlay.innerHTML = `<img src="${src}" alt="${alt}" /><button class="screenshot-lightbox-close" aria-label="Close">&times;</button>`;
        overlay.addEventListener('click', (e) => {
          if (e.target === overlay || (e.target as HTMLElement).closest('.screenshot-lightbox-close')) {
            overlay.remove();
          }
        });
        document.addEventListener('keydown', function handler(e) {
          if (e.key === 'Escape') { overlay.remove(); document.removeEventListener('keydown', handler); }
        });
        document.body.appendChild(overlay);
      });
    });
  }
  initLightbox();
  document.addEventListener('astro:page-load', initLightbox);
</script>
